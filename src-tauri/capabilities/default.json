{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "dialog:allow-open",
    "dialog:allow-ask",
    "store:default",
    "core:menu:default",
    "window-state:default",
    "clipboard-manager:allow-write-text"
  ]
}
